# ==============================================================================
# GENERAL & OS
# ==============================================================================
.DS_Store
Thumbs.db
*.swp
*.bak
*.tmp
.history
.direnv/

# ==============================================================================
# ENVIRONMENTS & SECRETS
# ==============================================================================
.env
.env.*
!.env.example
.venv/
venv/
env/
node_modules/
target/        # Rust build artifacts
bin/
obj/

# ==============================================================================
# PYTHON (Modern: uv, ruff, pytest)
# ==============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/
.ipynb_checkpoints/

# ==============================================================================
# JAVASCRIPT / TYPESCRIPT / WEB
# ==============================================================================
.npm/
dist/
out/
.next/
.nuxt/
.svelte-kit/
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ==============================================================================
# RUST
# ==============================================================================
# 'target/' is already covered in Environments, but added for clarity
# Cargo.lock is usually kept in binary projects, but ignored in some libs.
# For a general template, we keep it (don't ignore it).
**/*.rs.bk

# ==============================================================================
# IDEs & TOOLS
# ==============================================================================
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
.idea/
*.sublime-project
*.sublime-workspace

# ==============================================================================
# DATABASE & MEDIA
# ==============================================================================
*.sqlite
*.sqlite-journal
*.db
*.log
media/
storage/